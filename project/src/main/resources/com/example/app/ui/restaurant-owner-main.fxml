<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="650.0" minWidth="900.0" prefHeight="650.0" prefWidth="900.0" styleClass="anchor-pane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.ui.controller.RestaurantOwnerController">
   <children>
      <VBox prefWidth="220.0" spacing="10.0" styleClass="sidebar" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="80.0">
               <children>
                  <Button mnemonicParsing="false" styleClass="menu-button">
                     <graphic>
                        <ImageView fitHeight="35.0" fitWidth="35.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../images/menu.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
               </children>
               <padding>
                  <Insets left="15.0" />
               </padding>
            </HBox>
            <VBox spacing="15.0" VBox.vgrow="ALWAYS">
               <children>
                  <Button fx:id="myRestaurantsButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#openRestaurants" prefHeight="50.0" styleClass="nav-button" text="My Restaurants" />
                  <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#openStatistics" prefHeight="50.0" styleClass="nav-button" text="Statistics" />
               </children>
               <padding>
                  <Insets left="5.0" right="5.0" />
               </padding>
            </VBox>
         </children>
      </VBox>

      <VBox layoutX="220.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="220.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <ToolBar prefHeight="80.0" styleClass="top-toolbar">
               <items>
                  <HBox HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#addRestaurant" prefHeight="45.0" styleClass="action-button" text="Add New">
                     <graphic>
                        <ImageView fitHeight="25.0" fitWidth="25.0">
                           <image><Image url="@../images/add.png" /></image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button fx:id="deleteButton" mnemonicParsing="false" onAction="#deleteRestaurant" prefHeight="45.0" styleClass="action-button-delete" text="Delete">
                     <graphic>
                        <ImageView fitHeight="25.0" fitWidth="25.0">
                           <image><Image url="@../images/delete.png" /></image>
                        </ImageView>
                     </graphic>
                  </Button>
               </items>
               <padding>
                  <Insets left="25.0" right="25.0" />
               </padding>
            </ToolBar>

            <ScrollPane fitToWidth="true" prefWidth="680.0" styleClass="content-scroll" VBox.vgrow="ALWAYS">
               <content>
                  <FlowPane fx:id="restaurantFlowPane" hgap="25.0" vgap="25.0">
                     <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                     </padding>
                  </FlowPane>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </children>
</AnchorPane>
