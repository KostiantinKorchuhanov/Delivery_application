<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="600.0" minWidth="800.0" styleClass="border-pane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.presentation.controller.ChooseUserController">
   <right>
      <VBox minHeight="500.0" minWidth="400.0" BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets />
         </BorderPane.margin>
         <children>
            <HBox minHeight="65.0" minWidth="400.0">
               <children>
                  <ToggleButton fx:id="loginClicked" disable="true" mnemonicParsing="false" onMouseClicked="#loginClicked" prefHeight="25.0" prefWidth="100.0" selected="true" styleClass="login-button" text="Login">
                     <toggleGroup>
                        <ToggleGroup fx:id="loginType" />
                     </toggleGroup>
                     <font>
                        <Font name="DejaVuMathTeXGyre-Regular" size="16.0" />
                     </font>
                     <HBox.margin>
                        <Insets bottom="20.0" left="100.0" top="20.0" />
                     </HBox.margin>
                  </ToggleButton>
                  <ToggleButton fx:id="registerClicked" mnemonicParsing="false" onMouseClicked="#registerClicked" prefHeight="25.0" prefWidth="100.0" styleClass="login-button" text="Register" toggleGroup="$loginType">
                     <font>
                        <Font name="DejaVuMathTeXGyre-Regular" size="16.0" />
                     </font>
                     <HBox.margin>
                        <Insets bottom="20.0" right="100.0" top="20.0" />
                     </HBox.margin>
                  </ToggleButton>
               </children>
            </HBox>
            <StackPane>
               <children>
                  <VBox fx:id="registerBox" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="login-field" visible="false">
                     <children>
                        <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../images/user.png" />
                           </image>
                           <VBox.margin>
                              <Insets left="150.0" right="150.0" top="35.0" />
                           </VBox.margin>
                        </ImageView>
                        <TextField fx:id="nameField" maxWidth="1.7976931348623157E308" minHeight="30.0" promptText="Name" styleClass="test-field">
                           <VBox.margin>
                              <Insets left="75.0" right="75.0" top="10.0" />
                           </VBox.margin>
                        </TextField>
                        <TextField fx:id="surnameField" maxWidth="1.7976931348623157E308" minHeight="30.0" promptText="Surname" styleClass="text-field">
                           <VBox.margin>
                              <Insets left="75.0" right="75.0" top="10.0" />
                           </VBox.margin>
                        </TextField>
                        <TextField fx:id="usernameField" maxWidth="1.7976931348623157E308" minHeight="30.0" promptText="Username" styleClass="text-field">
                           <VBox.margin>
                              <Insets left="75.0" right="75.0" top="10.0" />
                           </VBox.margin>
                        </TextField>
                        <TextField fx:id="emailFieldRegister" maxWidth="1.7976931348623157E308" minHeight="30.0" promptText="Email" styleClass="text-field">
                           <VBox.margin>
                              <Insets left="75.0" right="75.0" top="10.0" />
                           </VBox.margin>
                        </TextField>
                        <TextField fx:id="phoneField" maxWidth="1.7976931348623157E308" minHeight="30.0" promptText="Phone" styleClass="text-field">
                           <VBox.margin>
                              <Insets left="75.0" right="75.0" top="10.0" />
                           </VBox.margin>
                        </TextField>
                        <PasswordField fx:id="passwordFieldRegister" maxWidth="1.7976931348623157E308" minHeight="30.0" promptText="Create password" styleClass="text-field">
                           <VBox.margin>
                              <Insets left="75.0" right="75.0" top="10.0" />
                           </VBox.margin>
                        </PasswordField>
                        <PasswordField fx:id="repeatPasswordField" maxWidth="1.7976931348623157E308" minHeight="30.0" promptText="Repeate password" styleClass="text-field">
                           <VBox.margin>
                              <Insets left="75.0" right="75.0" top="10.0" />
                           </VBox.margin>
                        </PasswordField>
                        <ComboBox fx:id="selectUser" prefWidth="150.0" promptText="Select user" styleClass="combo-box" visibleRowCount="4">
                           <items>
                              <FXCollections fx:factory="observableArrayList">
                                 <String fx:id="customerSelected" fx:value="Customer" />
                                 <String fx:id="driverSelected" fx:value="Driver" />
                                 <String fx:id="restaurantSelected" fx:value="Restaurant" />
                                 <String fx:id="adminSelected" fx:value="Admin" />
                              </FXCollections>
                           </items>
                           <VBox.margin>
                              <Insets left="125.0" right="125.0" top="10.0" />
                           </VBox.margin>

                        </ComboBox>
                        <Button fx:id="registerButton" disable="true" minHeight="30.0" minWidth="100.0" mnemonicParsing="false" onMouseClicked="#registerNewUser" styleClass="buttons" text="Register">
                           <font>
                              <Font name="DejaVuMathTeXGyre-Regular" size="16.0" />
                           </font>
                           <VBox.margin>
                              <Insets left="150.0" right="150.0" top="50.0" />
                           </VBox.margin>
                        </Button>
                     </children>
                  </VBox>
                  <VBox fx:id="loginBox" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="login-field">
                     <children>
                        <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../images/user.png" />
                           </image>
                           <VBox.margin>
                              <Insets left="150.0" right="150.0" top="35.0" />
                           </VBox.margin>
                        </ImageView>
                        <TextField fx:id="emailFieldLogin" maxWidth="1.7976931348623157E308" minHeight="30.0" promptText="Email" styleClass="text-field">
                           <VBox.margin>
                              <Insets left="75.0" right="75.0" top="10.0" />
                           </VBox.margin>
                        </TextField>
                        <PasswordField fx:id="passwordFieldLogin" maxWidth="1.7976931348623157E308" minHeight="30.0" promptText="Password" styleClass="text-field">
                           <VBox.margin>
                              <Insets left="75.0" right="75.0" top="10.0" />
                           </VBox.margin>
                        </PasswordField>
                        <Button fx:id="loginButton" disable="true" minHeight="30.0" minWidth="100.0" mnemonicParsing="false" onMouseClicked="#loginUser" styleClass="buttons" text="Login">
                           <font>
                              <Font name="DejaVuMathTeXGyre-Regular" size="16.0" />
                           </font>
                           <VBox.margin>
                              <Insets left="150.0" right="150.0" top="50.0" />
                           </VBox.margin>
                        </Button>
                     </children>
                  </VBox>
               </children>
            </StackPane>
         </children>
      </VBox>
   </right>
   <left>
      <ImageView fitHeight="393.0" fitWidth="411.0" pickOnBounds="true" preserveRatio="true" BorderPane.alignment="CENTER">
         <image>
            <Image url="@../images/logo.png" />
         </image>
      </ImageView>
   </left>
</BorderPane>
